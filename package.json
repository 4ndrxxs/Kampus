{
    "name":  "kampus",
    "private":  true,
    "version":  "0.1.0",
    "description":  "Korean Campus CLI - school information toolkit for Korea",
    "author":  "Juwon Seo <contact@seojuwon.com>",
    "license":  "MIT",
    "engines":  {
                    "node":  "\u003e=20.0.0"
                },
    "packageManager":  "pnpm@10.32.1",
    "scripts":  {
                    "build":  "pnpm -r run build",
                    "test":  "pnpm -r run test",
                    "lint":  "pnpm exec eslint .",
                    "clean":  "pnpm -r run clean",
                    "typecheck":  "pnpm -r run typecheck",
                    "verify":  "pnpm clean \u0026\u0026 pnpm lint \u0026\u0026 pnpm typecheck \u0026\u0026 pnpm build \u0026\u0026 pnpm test",
                    "smoke:live":  "pnpm --filter @kampus/cli dev doctor --live --json",
                    "smoke:keyed":  "pnpm build \u0026\u0026 node ./scripts/smoke-keyed.mjs",
                    "pack:cli":  "node ./scripts/pack-cli.mjs",
                    "smoke:pack:cli":  "node ./scripts/smoke-pack-cli.mjs"
                },
    "pnpm":  {
                 "onlyBuiltDependencies":  [
                                               "esbuild"
                                           ]
             },
    "devDependencies":  {
                            "@eslint/js":  "^9.25.0",
                            "@types/node":  "^25.4.0",
                            "esbuild":  "^0.25.10",
                            "eslint":  "^9.25.0",
                            "globals":  "^16.4.0",
                            "typescript-eslint":  "^8.31.1",
                            "typescript":  "^5.9.3"
                        },
    "repository":  {
                       "type":  "git",
                       "url":  "git+https://github.com/4ndrxxs/Kampus.git"
                   },
    "homepage":  "https://github.com/4ndrxxs/Kampus#readme",
    "bugs":  {
                 "url":  "https://github.com/4ndrxxs/Kampus/issues"
             }
}

