{
    "name":  "@kampus/core",
    "version":  "0.1.0",
    "description":  "Core library for Kampus - Korean school information toolkit",
    "type":  "module",
    "main":  "dist/index.js",
    "types":  "src/index.ts",
    "exports":  {
                    ".":  {
                              "types":  "./src/index.ts",
                              "import":  "./dist/index.js"
                          }
                },
    "scripts":  {
                    "build":  "node ../../scripts/clean-package.mjs \u0026\u0026 tsc -p tsconfig.build.json",
                    "clean":  "node ../../scripts/clean-package.mjs",
                    "typecheck":  "tsc --noEmit",
                    "test":  "vitest run --passWithNoTests",
                    "test:watch":  "vitest"
                },
    "dependencies":  {
                         "iconv-lite":  "^0.6.3"
                     },
    "devDependencies":  {
                            "typescript":  "^5.8.0",
                            "vitest":  "^3.0.0"
                        },
    "repository":  {
                       "type":  "git",
                       "url":  "git+https://github.com/4ndrxxs/Kampus.git"
                   },
    "homepage":  "https://github.com/4ndrxxs/Kampus#readme",
    "bugs":  {
                 "url":  "https://github.com/4ndrxxs/Kampus/issues"
             }
}

